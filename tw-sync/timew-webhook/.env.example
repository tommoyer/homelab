# Copy to .env and edit as needed
TOKEN=change-me-to-a-long-random-string

# Where your host Timewarrior data lives (Syncthing-backed on Swarm)
# Example Syncthing folder on Swarm node: /srv/sync/timewarrior
TIMEW_HOME=/srv/sync/timewarrior

# Run the container as this UID/GID (must match folder ownership)
PUID=0
PGID=0

# Host port to expose
PORT=9000
