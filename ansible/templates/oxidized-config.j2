username: {{ oxidized_username }}
password: {{ oxidized_password }}
model: {{ oxidized_model | default('routeros') }}
interval: 3600
log: ~/.config/oxidized/log
debug: false
threads: 30
timeout: 20
retries: 3

output:
  default: git
  git:
    user: {{ oxidized_git_user | default('Oxidized') }}
    email: {{ oxidized_git_email | default('oxidized@example.com') }}
    repo: "{{ oxidized_git_repo | default('~/.config/oxidized/oxidized.git') }}"

source:
  default: csv
  csv:
    file: ~/.config/oxidized/router.db
    delimiter: !ruby/regexp /:/
    map:
      name: 0
      model: 1
      username: 2
      password: 3