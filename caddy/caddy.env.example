# Environment variables consumed by the Caddy systemd service.
#
# Where to place this file depends on your distro/package.
# On many Debian/Ubuntu installs it is: /etc/caddy/env
# Verify with: systemctl cat caddy | sed -n '/EnvironmentFile/p'

CLOUDFLARE_API_TOKEN="your_cloudflare_api_token_here"
ACME_EMAIL="tommoyer@gmail.com"
