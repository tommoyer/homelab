# ------------------------------------------------------------------
# Public Wildcard Handler (moyer.wtf)
# ------------------------------------------------------------------
*.moyer.wtf moyer.wtf {
    # 1. Cloudflare DNS Challenge for Wildcard Certs
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }

    # 2. Service Map (Hostname -> Backend IP in Homelab VLAN 10)
    map {host} {backend} {
        # Generated by update-network-configs.py on 2025-12-31 18:35:58.630646
        pihole.moyer.wtf        192.168.1.4:80
        tb-nas.moyer.wtf        192.168.10.7:443
        cookbook.moyer.wtf      192.168.10.8:8002
        ledger.moyer.wtf        192.168.10.9:80
        sync.moyer.wtf          192.168.10.12:8384
        git.moyer.wtf           192.168.10.13:3000
        news.moyer.wtf          192.168.10.14:8280
        vault.moyer.wtf         192.168.10.16:8000
        home.moyer.wtf          192.168.10.17:7575
        kuma.moyer.wtf          192.168.10.19:3001
        grafana.moyer.wtf       192.168.10.20:3000
        tw-sync.moyer.wtf       192.168.10.21
        unifi.moyer.wtf         192.168.10.22:8443
        pihole-lab.moyer.wtf    192.168.10.27:80
        proxmox.moyer.wtf       192.168.10.29:8006
        pihole-dmz.moyer.wtf    192.168.20.2:80

        default                 unknown
    }

    # 3. Proxmox Handler (Special case: HTTPS backend + Self-Signed)
    @proxmox host proxmox.moyer.wtf
    handle @proxmox {
        reverse_proxy https://192.168.10.29:8006 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    @unifi host unifi.moyer.wtf
    handle @unifi {
        reverse_proxy https://192.168.10.22:8443 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    @tb-nas host tb-nas.moyer.wtf
    handle @tb-nas {
        reverse_proxy https://192.168.10.7:443 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    @vault host vault.moyer.wtf
    handle @vault {
        reverse_proxy https://192.168.10.16:8000 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    # 4. Generic Handler (Standard HTTP backends)
    @mapped expression {backend} != "unknown"
    handle @mapped {
        reverse_proxy {backend}
    }

    # 5. Fallback for undefined subdomains
    handle {
        respond "Service not defined in Caddy Map" 404
    }
}

# ------------------------------------------------------------------
# Public Web: thomasmoyer.org (redirect www -> apex)
# ------------------------------------------------------------------
*.thomasmoyer.org thomasmoyer.org {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }

    @www host www.thomasmoyer.org
    redir @www https://thomasmoyer.org{uri}

    map {host} {backend} {
        # Generated by update-network-configs.py on 2025-12-31 18:35:58.630673
        www.thomasmoyer.org    192.168.10.15:8080
        thomasmoyer.org        192.168.10.15:8080

        default                 unknown
    }

    @mapped expression {backend} != "unknown"
    handle @mapped {
        reverse_proxy {backend}
    }

    handle {
        respond "Service not defined in Caddy Map" 404
    }
}

