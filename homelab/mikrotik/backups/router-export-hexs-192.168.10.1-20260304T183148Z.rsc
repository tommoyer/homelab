    vlan-ids=10
add bridge=br-lan tagged=br-lan,ether2 vlan-ids=20
add bridge=br-lan tagged=br-lan,ether2 vlan-ids=30
add bridge=br-lan tagged=br-lan,ether2,ether3,ether4 vlan-ids=100
