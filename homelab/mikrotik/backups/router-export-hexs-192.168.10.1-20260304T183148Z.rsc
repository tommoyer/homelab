/interface bridge
add name=br-lan protocol-mode=none vlan-filtering=yes
/interface vlan
add interface=br-lan name=vlan10-mgmt vlan-id=10
add interface=br-lan name=vlan20-dmz vlan-id=20
add interface=br-lan name=vlan30-homelab vlan-id=30
add interface=br-lan name=vlan100-clients vlan-id=100
/interface list
